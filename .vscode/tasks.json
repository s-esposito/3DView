{
  "version": "2.0.0",
  "options": {
    "env": {
      // node/npm live in a conda env, not on the system PATH. Prepend the env's
      // bin so the npm tasks below (and "Run Extension"'s preLaunchTask) resolve
      // npm. ${env:HOME} keeps this off any hardcoded username path.
      "PATH": "${env:HOME}/.conda/envs/sam3d-objects/bin:${env:PATH}"
    }
  },
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "problemMatcher": "$esbuild",
      "label": "npm: build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "label": "npm: watch"
    }
  ]
}
