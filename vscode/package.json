{
  "name": "3dviewer",
  "displayName": "3DViewer",
  "description": "View COLMAP reconstructions in the editor as a colored point cloud with camera poses.",
  "version": "0.0.1",
  "publisher": "3dviewer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-esposito/3DView.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "3dviewer",
          "title": "3DViewer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "3dviewer": [
        {
          "id": "3dviewer.welcome",
          "name": "3DViewer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "3dviewer.welcome",
        "contents": "View a COLMAP reconstruction as a colored point cloud with camera poses.\n[Open Reconstruction](command:3dviewer.openReconstruction)\n\nOr load a mesh (glTF / GLB / OBJ / PLY) into the scene.\n[Open Mesh](command:3dviewer.openMesh)\n\nOr just open an empty viewer.\n[Open Viewer](command:3dviewer.openViewer)\n\nTip: drag a folder or a mesh file here to open it. Recently opened items appear in this panel."
      }
    ],
    "commands": [
      {
        "command": "3dviewer.openReconstruction",
        "title": "3DViewer: Open Reconstruction",
        "icon": "$(folder-opened)"
      },
      {
        "command": "3dviewer.openMesh",
        "title": "3DViewer: Open Mesh",
        "icon": "$(file)"
      },
      {
        "command": "3dviewer.openViewer",
        "title": "3DViewer: Open Empty Viewer",
        "icon": "$(empty-window)"
      },
      {
        "command": "3dviewer.openRecent",
        "title": "3DViewer: Open Recent"
      },
      {
        "command": "3dviewer.removeRecent",
        "title": "Remove from Recents",
        "icon": "$(close)"
      },
      {
        "command": "3dviewer.revealRecent",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "3dviewer.clearRecents",
        "title": "3DViewer: Clear Recents",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "3dviewer.openReconstruction", "when": "view == 3dviewer.welcome", "group": "navigation@1" },
        { "command": "3dviewer.openMesh", "when": "view == 3dviewer.welcome", "group": "navigation@2" },
        { "command": "3dviewer.openViewer", "when": "view == 3dviewer.welcome", "group": "navigation@3" },
        { "command": "3dviewer.clearRecents", "when": "view == 3dviewer.welcome", "group": "1_recents@1" }
      ],
      "view/item/context": [
        { "command": "3dviewer.revealRecent", "when": "view == 3dviewer.welcome && viewItem == recent", "group": "navigation@1" },
        { "command": "3dviewer.removeRecent", "when": "view == 3dviewer.welcome && viewItem == recent", "group": "navigation@2" }
      ],
      "commandPalette": [
        { "command": "3dviewer.openRecent", "when": "false" },
        { "command": "3dviewer.removeRecent", "when": "false" },
        { "command": "3dviewer.revealRecent", "when": "false" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit -p ./",
    "test": "node esbuild.js --test && node --test \"out/test/*.test.js\""
  },
  "devDependencies": {
    "@3dviewer/core": "*",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
